# Mission Control local development template
# Copy this file to `.env.local` and replace the placeholder values.

# Existing app secret for offline HMAC license generation.
MC_LICENSE_SECRET=replace-with-32-plus-character-secret

# Stripe test mode
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PERSONAL=price_replace_personal
STRIPE_PRICE_PRO=price_replace_pro
STRIPE_PRICE_TEAM=price_replace_team

# Optional SMTP email delivery for fulfilled license keys
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=licenses@example.com
SMTP_FROM_NAME=Mission Control
SMTP_REPLY_TO=support@orqpilot.com
MISSION_CONTROL_SUPPORT_EMAIL=support@orqpilot.com

# Public site URLs used by checkout / success pages
MISSION_CONTROL_SITE_URL=http://127.0.0.1:3000
MISSION_CONTROL_DOWNLOAD_URL=https://github.com/Toma505/mission-control/releases/latest
NEXT_PUBLIC_MISSION_CONTROL_PRICING_URL=http://127.0.0.1:3000/pricing/
