// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  tagline      String
  description  String
  status       String   @default("IDLE")
  avatar       String?
  capabilities String   @default("[]") // JSON array
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks        TaskAgent[]
  activities   Activity[]
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String
  status      String      @default("BACKLOGGED")
  progress    Int         @default(0)
  priority    String      @default("MEDIUM")
  tags        String      @default("[]") // JSON array
  dueDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  completedAt DateTime?

  assignedAgents TaskAgent[]
  activities     Activity[]
}

// Join table for many-to-many Agent <-> Task
model TaskAgent {
  id      String @id @default(cuid())
  agent   Agent  @relation(fields: [agentId], references: [id])
  agentId String
  task    Task   @relation(fields: [taskId], references: [id])
  taskId  String

  @@unique([agentId, taskId])
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  entityId    String?
  entityType  String?
  status      String   @default("IN_PROGRESS")
  metadata    String?  // JSON string
  timestamp   DateTime @default(now())

  agent       Agent?   @relation(fields: [agentId], references: [id])
  agentId     String?
  task        Task?    @relation(fields: [taskId], references: [id])
  taskId      String?
}

model Commit {
  id              String   @id @default(cuid())
  message         String
  author          String
  timestamp       DateTime @default(now())
  relatedTaskId   String?
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  size        Int
  path        String
  uploadedBy  String
  uploadedAt  DateTime @default(now())
  tags        String   @default("[]") // JSON array
}

model Client {
  id           String   @id @default(cuid())
  name         String
  status       String   @default("ACTIVE")
  lastActivity DateTime?
  metadata     String?  // JSON string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CronJob {
  id       String   @id @default(cuid())
  name     String
  schedule String
  status   String   @default("ACTIVE")
  lastRun  DateTime?
  nextRun  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemStatus {
  id           String   @id @default(cuid())
  overall      String   @default("ACTIVE")
  message      String
  lastChecked  DateTime @default(now())
  agentsActive Int      @default(0)
  tasksInProgress Int   @default(0)
  systemLoad   Float    @default(0)
}
